#!/bin/sh
# Thin wrapper around pandoc that bridges:
#
# 1. pandoc accepts the source format either explicitly
#    (--from / -f) or by auto-detecting from the upload's
#    filename extension. url2code preserves the original
#    extension on the saved upload, so auto-detect works
#    out of the box. This wrapper takes the *target* format
#    as a positional arg and any flag-rendered extras (-f,
#    -s, ...) come through ``$@`` from url2code's flag
#    rendering.
#
# 2. stderr -> stdout. pandoc writes warnings and errors
#    to stderr; url2code's text-mode parser only reads
#    stdout. The ``2>&1`` makes failures visible in the
#    response body.
#
# 3. ``-o`` is explicit. url2code generates an output path
#    that may contain characters pandoc would mistake for
#    a positional arg ordering. Passing it via ``-o`` is
#    unambiguous.
#
# 4. Citeproc (optional). A bibliography and an optional CSL style
#    arrive as positional args 4 and 5 — each an EMPTY STRING when
#    its optional upload (config/tools.yaml uploads required:false)
#    was omitted. When a bibliography is present the wrapper turns
#    on ``--citeproc --bibliography=<file>`` (+ ``--csl=<file>`` if
#    a style was uploaded); when absent the conversion is plain.
#
# usage:
#   pandoc-convert <input> <output> <writer> [bib] [csl] [extra...]
#
# extra_args (the url2code-rendered -f / -s flags) are forwarded to
# pandoc before the input path.

set -e

INPUT="$1"
OUTPUT="$2"
WRITER="$3"
BIB="$4"   # optional bibliography path ("" if not uploaded)
CSL="$5"   # optional CSL style path   ("" if not uploaded)
shift 5 2>/dev/null || shift "$#"

if [ -z "$INPUT" ] || [ -z "$OUTPUT" ] || [ -z "$WRITER" ]; then
    echo "usage: pandoc-convert <input> <output> <writer> [bib] [csl] [extra...]" >&2
    exit 64
fi

if [ ! -f "$INPUT" ]; then
    echo "input file does not exist: $INPUT" >&2
    exit 66
fi

# Prepend citeproc flags onto $@ (the -f/-s extras) when a
# bibliography was supplied; no-op for a plain conversion.
if [ -n "$CSL" ]; then
    set -- --csl="$CSL" "$@"
fi
if [ -n "$BIB" ]; then
    set -- --citeproc --bibliography="$BIB" "$@"
fi

if [ "$WRITER" = "pdf" ]; then
    # No LaTeX/TeX backend in the image. Produce PDF via
    # weasyprint's HTML/CSS engine. pandoc infers PDF from the
    # .pdf output extension, so omit ``-t`` (there is no
    # ``-t pdf`` writer) and point it at the engine. The extra
    # flags ($@) from url2code's flag rendering (-f / -s) are
    # forwarded the same as for any other target.
    #
    # pandoc writes its PDF intermediate into the *current
    # directory*, which is /app — read-only under container
    # hardening (read_only root + tmpfs /tmp). Run from a writable
    # scratch dir on the tmpfs. INPUT and OUTPUT are absolute, so
    # the cd doesn't disturb them.
    SCRATCH="$(mktemp -d)"
    trap 'rm -rf "$SCRATCH"' EXIT
    cd "$SCRATCH"
    pandoc \
        -o "$OUTPUT" \
        --pdf-engine=weasyprint \
        "$@" \
        "$INPUT" 2>&1
    exit $?
fi

exec pandoc \
    -t "$WRITER" \
    -o "$OUTPUT" \
    "$@" \
    "$INPUT" 2>&1
